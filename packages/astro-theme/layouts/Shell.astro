---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

interface Props {
	title?: string;
	description?: string | undefined;
	image?: string | undefined;
	site?: string; // to discriminate colour scheme by site
	filterPage?: boolean; // true on pages with a ProductFilter (showcase, blog)
}

const { title, description, image, site, filterPage = false } = Astro.props;
---

<!doctype html>
<html lang="en" class={`dark scroll-smooth ${site ? `site-${site}` : ""}`}>
	<head>
		<BaseHead
			title={title || SITE_TITLE}
			description={description || SITE_DESCRIPTION}
			{image}
		/>
		<style is:inline is:global>
			@font-face {
				font-family: "Monaspace Argon";
				src: url("/fonts/monaspace/MonaspaceArgonVarVF.woff2") format("woff2");
				font-display: swap;
			}
		</style>
		<style is:global>
			.dark {
				color-scheme: dark;
			}

			::selection {
				background-color: rgba(230, 39, 85, 0.5);
			}

			.heading-link-icon {
				opacity: 0;
			}

			h1:hover .heading-link-icon,
			h2:hover .heading-link-icon,
			h3:hover .heading-link-icon,
			h4:hover .heading-link-icon,
			h5:hover .heading-link-icon {
				opacity: 1;
			}

			code {
				/* Leaning Technologies ;) */
				font-variation-settings: "slnt" -9 !important;

				/* Enable texture healing and ligatures */
				font-feature-settings:
					"calt" var(--texture-healing, 1),
					"dlig" var(--ligatures, 1),
					"ss01" var(--ligatures, 1),
					"ss02" var(--ligatures, 1),
					"ss03" var(--ligatures, 1),
					"ss04" var(--ligatures, 1),
					"ss05" var(--ligatures, 1),
					"ss06" var(--ligatures, 1),
					"ss07" var(--ligatures, 1),
					"ss08" var(--ligatures, 1) !important;
			}

			/* inline code */
			.prose
				:where(code):not(:where([class~="not-prose"], [class~="not-prose"] *)) {
				@apply bg-bg-800;

				padding: 0.2em 0.4em;
				font-size: 90%;

				border-radius: 6px;

				white-space: break-spaces;

				/* No italics because we're already slanted */
				& span {
					font-style: normal !important;
				}
			}

			/* Don't wrap between link text and the 'external link' icon */
			.prose a:has(> span > img) {
				white-space: nowrap;
			}

			p,
			li {
				text-wrap: pretty;
			}
		</style>
		<!--
			FOUC guard for pages with a ProductFilter (/showcase, /blog).

			Because this is a static site, ProductFilter.svelte runs client-side only
			(client:load). There is a window between initial SSR paint and Svelte
			hydration where the filter section can flicker or shift — regardless of
			whether a filter is active in the URL.

			When filterPage={true}, this inline script runs synchronously in <head>
			and adds "filtering-pending" to <html> before the browser paints any body
			content. The style block below uses this class to hide [data-filter-section]
			(the filter bar + card grid on showcase/blog pages).

			ProductFilter.svelte initialises its filter state synchronously from the URL
			(outside onMount), so its first rendered output already shows the correct
			filtered state. A $effect removes "filtering-pending" after that first
			render, so the section fades in cleanly.

			This is the same no-FOUC pattern used for dark-mode theme scripts.
		-->
		<script is:inline define:vars={{ filterPage }}>
			if (filterPage) {
				document.documentElement.classList.add("filtering-pending");
			}
		</script>
		<style is:global>
			[data-filter-grid],
			[data-filter-section] {
				transition: opacity 0.35s ease;
			}
			html.filtering-pending [data-filter-grid],
			html.filtering-pending [data-filter-section] {
				opacity: 0;
				pointer-events: none;
			}
		</style>
	</head>
	<body
		class="font-sans antialiased min-w-full min-h-screen flex flex-col m-0 p-0 bg-bg-900 text-bg-200"
	>
		<slot />
	</body>
</html>
