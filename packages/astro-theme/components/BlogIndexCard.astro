---
import { getEntry, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "./FormattedDate.astro";
import { resolveAuthors } from "../lib/blog";

interface Props {
	post: CollectionEntry<"blog"> | CollectionEntry<"blog">["slug"];
	featured?: boolean;
}

const { post: postOrSlug, featured = false } = Astro.props;

if (!postOrSlug) return null;

const post =
	typeof postOrSlug === "string"
		? await getEntry("blog", postOrSlug)
		: postOrSlug;

const authors = await resolveAuthors(post.data.authors);
---

<a
	href={`/blog/${post.slug}`}
	class="inline-flex flex-col group not-prose w-full p-3 sm:p-6"
>
	{
		post.data.heroImage && (
			<div
				class={`card-image relative overflow-hidden border border-stone-800 group-hover:border-stone-500 transition-colors rounded-sm w-full ${featured ? "h-48 sm:h-64" : "h-32 sm:h-48"} mb-3 sm:mb-5 bg-stone-900`}
			>
				<Image
					src={post.data.heroImage}
					width={1170}
					height={615}
					format="webp"
					alt=""
					class="absolute inset-0 w-full h-full object-cover"
				/>
			</div>
		)
	}
	<h3
		class={`card-title font-bold text-balance text-white group-hover:text-primary-400 ${featured ? "text-xl" : "text-base"} leading-snug mb-2 grow`}
	>
		{post.data.title}
	</h3>
	{
		post.data.description && (
			<p class="text-stone-400 text-sm leading-relaxed line-clamp-2 mb-4">
				{post.data.description}
			</p>
		)
	}
	<div
		class="flex justify-between items-center gap-4 text-stone-500 text-xs whitespace-nowrap"
	>
		<div class="flex items-center gap-1.5 overflow-hidden">
			<div class="flex -space-x-1.5 flex-none">
				{
					authors.map((author) =>
						author.avatar ? (
							<img
								class="w-5 h-5 rounded-full border border-stone-700"
								src={author.avatar.src}
								alt=""
								loading="lazy"
								decoding="async"
							/>
						) : undefined
					)
				}
			</div>
			<span class="overflow-hidden text-ellipsis">
				{authors.map((a) => a.name).join(", ")}
			</span>
			{
				authors.some((a) => a.guest) && (
					<span class="py-0.5 px-1.5 bg-primary-400/30 border border-primary-400 text-primary-200 rounded-full text-xs font-semibold">
						Guest
					</span>
				)
			}
		</div>
		<FormattedDate date={post.data.pubDate} />
	</div>
</a>
