---
import { getCollection } from "astro:content";
import BlogIndexCard from "@leaningtech/astro-theme/components/BlogIndexCard.astro";
import Shell from "@leaningtech/astro-theme/layouts/Shell.astro";
import Footer from "@leaningtech/astro-theme/components/Footer.astro";
import { getSite } from "@leaningtech/astro-theme/nav";
import ProductFilter from "../../components/ProductFilter.svelte";
import FilterPaintGuard from "@leaningtech/astro-theme/components/FilterPaintGuard.astro";

const allPosts = (
	await getCollection("blog", ({ data }) => data.draft !== true)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const site = getSite(Astro.site?.hostname);
---

<Shell
	title="Engineering blog"
	description="Read the latest updates from the Leaning Technologies development team about WebAssembly, compilers, and more."
	{site}
>
	<div class="bg-stone-950">
		<header class="text-center py-16">
			<h1
				class="text-6xl md:text-7xl font-bold tracking-tight text-balance mb-6 pb-2 bg-gradient-to-b from-white to-stone-400 bg-clip-text text-transparent"
			>
				Engineering blog
			</h1>
			<p class="text-lg text-balance text-stone-400 max-w-xl mx-auto">
				News, technical writeups, and announcements directly from the
				development team.
			</p>
		</header>

		<section class="pb-24 px-4 sm:px-8 mx-auto w-full max-w-screen-xl" data-filter-section>
			<FilterPaintGuard />
			<ProductFilter client:load searchPlaceholder="Search posts…" />
			<ul class="grid grid-cols-2 md:grid-cols-6" data-filter-grid="blog">
				{
					allPosts.map((post, i) => {
						const featured = i < 4;
						const rIdx = i - 4;
						const borderR = featured ? i % 2 === 0 : rIdx % 3 < 2;
						const borderT = featured ? i >= 2 : true;
						return (
							<li
								class={`flex md:justify-stretch md:items-stretch border-stone-800
									${featured ? "col-span-2 md:col-span-3" : "col-span-1 md:col-span-2"}
									${borderR ? "md:border-r" : ""}
									${borderT ? "md:border-t" : ""}
								`}
								data-tags={post.data.tags?.join(",") ?? ""}
								data-categories={post.data.categories?.join(",") ?? ""}
								data-title={post.data.title}
								data-description={post.data.description}
								data-href={`/blog/${post.slug}`}
							>
								<BlogIndexCard {post} {featured} />
							</li>
						);
					})
				}
				<li
					data-empty-state
					style="display:none"
					class="col-span-full py-24 text-center"
				>
					<p class="text-stone-500 text-lg">Nothing to show here ;(</p>
				</li>
			</ul>
		</section>
	</div>

	<Footer />
</Shell>
