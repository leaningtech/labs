---
import { getCollection, getEntry } from "astro:content";
import { getImage } from "astro:assets";
import Shell from "@leaningtech/astro-theme/layouts/Shell.astro";
import Footer from "@leaningtech/astro-theme/components/Footer.astro";
import { getSite } from "@leaningtech/astro-theme/nav";
import ProductFilter from "../../components/ProductFilter.svelte";

const allPosts = (
	await getCollection("blog", ({ data }) => data.draft !== true)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const site = getSite(Astro.site?.hostname);

const blogCards = await Promise.all(
	allPosts.map(async (post) => {
		const authorEntries = await Promise.all(
			post.data.authors.map((id) => getEntry("blogauthors", id)),
		);
		const imageSrc = post.data.heroImage
			? (
					await getImage({
						src: post.data.heroImage,
						width: 1170,
						height: 615,
						format: "webp",
					})
				).src
			: undefined;
		return {
			slug: post.slug,
			title: post.data.title,
			description: post.data.description,
			href: `/blog/${post.slug}`,
			imageSrc,
			tags: post.data.tags ?? [],
			categories: post.data.categories ?? [],
			pubDate: post.data.pubDate.toISOString(),
			authors: authorEntries.map((a) => ({
				name: a?.data.name ?? "",
				avatarSrc: a?.data.avatar?.src,
				guest: a?.data.guest ?? false,
			})),
		};
	}),
);
---

<Shell
	title="Engineering blog"
	description="Read the latest updates from the Leaning Technologies development team about WebAssembly, compilers, and more."
	{site}
	filterPage={true}
>
	<div class="bg-stone-950">
		<header class="text-center py-16">
			<h1
				class="text-6xl md:text-7xl font-bold tracking-tight text-balance mb-6 pb-2 bg-gradient-to-b from-white to-stone-400 bg-clip-text text-transparent"
			>
				Engineering blog
			</h1>
			<p class="text-lg text-balance text-stone-400 max-w-xl mx-auto">
				News, technical writeups, and announcements directly from the
				development team.
			</p>
		</header>

		<section
			class="pb-24 px-4 sm:px-8 mx-auto w-full max-w-screen-xl"
			data-filter-section
		>
			<ProductFilter
				client:load
				searchPlaceholder="Search posts…"
				cards={blogCards}
				gridType="blog"
			/>
		</section>
	</div>

	<Footer />
</Shell>
